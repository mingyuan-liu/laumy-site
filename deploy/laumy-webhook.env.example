WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8789
WEBHOOK_PATH=/deploy-hook
WEBHOOK_HEALTH_PATH=/deploy-hook/healthz

# Use a long random value. The same value is used as:
# - GitHub native webhook Secret
# - GitHub Actions Authorization bearer token
WEBHOOK_SECRET=replace-with-a-long-random-secret

# Only these repositories and refs are allowed to trigger deploys.
ALLOWED_REPOSITORIES=<owner>/<content-repo>
ALLOWED_REFS=refs/heads/main

DEPLOY_SERVICE=laumy-git-deploy.service
LOG_LEVEL=INFO
