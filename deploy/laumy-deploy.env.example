SITE_DIR=/srv/laumy-site
CONTENT_DIR=/srv/laumy-notes-content

# GitHub branches to follow.
SITE_BRANCH=main
CONTENT_BRANCH=main

# Set to 1 when testing the pipeline and you want to deploy even when HEAD is unchanged.
FORCE=0

# Optional. Usually keep the default.
DEPLOY_CMD=/srv/laumy-site/scripts/deploy.sh
LOG_DIR=/var/log/laumy-deploy
